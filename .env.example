# Copia este archivo a .env y completá los valores. NUNCA subas .env al repo.

# --- LLM en la nube (opcional, solo cuando hay internet) ---
ANTHROPIC_API_KEY=

# --- Fuente de datos: simulator | recording | serial ---
MAREX_DATA_SOURCE=simulator

# --- Puerto serial del Maretron USB100 (cuando MAREX_DATA_SOURCE=serial) ---
# Windows: COM3 | Linux/Jetson: /dev/ttyUSB0
MAREX_SERIAL_PORT=

# --- Servidor API ---
MAREX_API_HOST=0.0.0.0
MAREX_API_PORT=8000
